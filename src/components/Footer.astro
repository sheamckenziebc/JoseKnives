---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer style="background-color:#0a0d14; border-top:1px solid rgba(200,169,110,0.1);" class="text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <img
            src={`${base}assets/logo.svg`}
            alt={`${config.site.title} logo`}
            class="h-10 w-auto filter brightness-0 invert"
            width="40"
            height="40"
          />
          <div class="flex flex-col">
            <span class="text-lg font-extrabold leading-tight" style="font-family: 'Cormorant Garamond', serif;">{config.site.title}</span>
            <span class="text-[10px] text-gray-400 font-medium uppercase tracking-widest">Custom Knives</span>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Custom knives and fine leatherwork. Every piece is built for beauty, performance and a lifetime of use.
        </p>
        <!-- Trust Badges -->
        <div class="flex flex-wrap items-center gap-3">
          <div class="flex items-center gap-1.5 text-xs text-gray-400 rounded-full px-3 py-1.5" style="background:rgba(212,80,10,0.12); border:1px solid rgba(212,80,10,0.2);">
            <span style="color:#d4500a;">⚒</span>
            Hand Forged
          </div>
          <div class="flex items-center gap-1.5 text-xs text-gray-400 rounded-full px-3 py-1.5" style="background:rgba(200,169,110,0.08); border:1px solid rgba(200,169,110,0.2);">
            <span style="color:#c8a96e;">✦</span>
            Fine Leatherwork
          </div>
        </div>
      </div>

      <!-- Browse -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">Browse</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={`${base}gallery/`} class="text-gray-400 hover:text-white transition-colors">Product Gallery</a></li>
          <li><a href={`${base}gallery/`} class="text-gray-400 hover:text-white transition-colors">Fine Leatherwork</a></li>
          <li><a href={`${base}artwork/`} class="text-gray-400 hover:text-white transition-colors">Custom Orders</a></li>
          <li><a href={`${base}about/`} class="text-gray-400 hover:text-white transition-colors">The Maker</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">Info</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={base} class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href={`${base}contact/`} class="text-gray-400 hover:text-white transition-colors">Contact</a></li>
          <li><a href={`${base}privacy/`} class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href={`${base}terms/`} class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">Get in Touch</h3>
        <div class="space-y-4 text-sm">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${config.contact.email}`} class="text-gray-400 hover:text-white transition-colors">{config.contact.email}</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-400">{config.contact.businessHours}</span>
          </div>
        </div>
        <div class="mt-6">
          <a href={`${base}contact/`} class="inline-flex items-center text-white px-5 py-2.5 rounded-lg font-bold text-sm transition-all hover:-translate-y-0.5" style="background:#d4500a; box-shadow:0 0 20px rgba(212,80,10,0.25);">
            Commission a Piece
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
      <p>&copy; {currentYear} J.M. Amoedo. All rights reserved.</p>
      <div class="flex gap-6 mt-3 md:mt-0">
        <a href={`${base}privacy/`} class="hover:text-gray-300 transition-colors">Privacy</a>
        <a href={`${base}terms/`} class="hover:text-gray-300 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
