---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-stone-900 text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <img
            src={`${base}assets/logo.svg`}
            alt={`${config.site.title} logo`}
            class="h-10 w-auto filter brightness-0 invert"
            width="40"
            height="40"
          />
          <div class="flex flex-col">
            <span class="text-lg font-extrabold leading-tight" style="font-family: 'Cormorant Garamond', serif;">{config.site.title}</span>
            <span class="text-[10px] text-gray-400 font-medium uppercase tracking-widest">Studio & Gallery</span>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Handmade, artistic and functional pottery by Franziska Cody. Located in the beautiful Bulkley Valley, Telkwa, BC.
        </p>
        <!-- Trust Badges -->
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-1.5 text-xs text-gray-400 bg-stone-800 px-3 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Handmade
          </div>
          <div class="flex items-center gap-1.5 text-xs text-gray-400 bg-stone-800 px-3 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Food Safe
          </div>
        </div>
      </div>

      <!-- Browse -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">Browse</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={`${base}gallery/`} class="text-gray-400 hover:text-white transition-colors">Pottery Gallery</a></li>
          <li><a href={`${base}artwork/`} class="text-gray-400 hover:text-white transition-colors">Other Artwork</a></li>
          <li><a href={`${base}gifts/`} class="text-gray-400 hover:text-white transition-colors">Other Gifts</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">Info</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={base} class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href={`${base}about/`} class="text-gray-400 hover:text-white transition-colors">Artist</a></li>
          <li><a href={`${base}contact/`} class="text-gray-400 hover:text-white transition-colors">Contact</a></li>
          <li><a href={`${base}privacy/`} class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href={`${base}terms/`} class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">Visit Us</h3>
        <div class="space-y-4 text-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-400">{config.contact.address}</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${config.contact.phone}`} class="text-gray-400 hover:text-white transition-colors font-medium">{config.contact.phone}</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${config.contact.email}`} class="text-gray-400 hover:text-white transition-colors">{config.contact.email}</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-400">{config.contact.businessHours}</span>
          </div>
        </div>

        <!-- Social Links -->
        <div class="flex gap-3 mt-6">
          {config.social.facebook && (
            <a href={config.social.facebook} class="w-9 h-9 bg-stone-800 rounded-lg flex items-center justify-center text-gray-400 hover:text-white hover:bg-stone-700 transition-all" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
            </a>
          )}
          {config.social.instagram && (
            <a href={config.social.instagram} class="w-9 h-9 bg-stone-800 rounded-lg flex items-center justify-center text-gray-400 hover:text-white hover:bg-stone-700 transition-all" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Kabir Quote -->
  <div class="border-t border-stone-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <blockquote class="text-center max-w-2xl mx-auto">
        <p class="text-gray-500 text-sm italic leading-relaxed" style="font-family: 'Cormorant Garamond', serif; font-size: 1rem;">
          "Inside this clay jug, there are canyons and pine mountains, and the maker of canyons and pine mountains."
        </p>
        <cite class="text-gray-600 text-xs mt-2 block not-italic">— Kabir</cite>
      </blockquote>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-stone-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center text-xs text-gray-500">
      <p>&copy; {currentYear} Franziska Gallert. All rights reserved. Telkwa, BC, Canada.</p>
      <div class="flex gap-6 mt-3 md:mt-0">
        <a href={`${base}privacy/`} class="hover:text-gray-300 transition-colors">Privacy</a>
        <a href={`${base}terms/`} class="hover:text-gray-300 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
