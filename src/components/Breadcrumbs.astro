---
// Generate breadcrumbs from current path
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Strip the base path prefix to get the relative path segments
const relativePath = currentPath.startsWith(base) ? currentPath.slice(base.length) : currentPath;
const pathSegments = relativePath.split('/').filter(segment => segment !== '');

interface Breadcrumb {
  name: string;
  href: string;
}

const breadcrumbs: Breadcrumb[] = [
  { name: 'Home', href: base }
];

// Build breadcrumb trail
let currentHref = base;
pathSegments.forEach((segment, index) => {
  currentHref += `${segment}/`;

  // Convert segment to readable name
  let name = segment.charAt(0).toUpperCase() + segment.slice(1);
  name = name.replace(/-/g, ' ');

  // Handle special cases
  if (segment === 'blog' && index < pathSegments.length - 1) {
    name = 'Blog';
  } else if (segment === 'services' && index < pathSegments.length - 1) {
    name = 'Services';
  }

  breadcrumbs.push({ name, href: currentHref });
});

// Pre-compute JSON-LD for breadcrumbs
const bcItems = breadcrumbs.map((crumb, index) => {
  const item: Record<string, any> = { position: index + 1, name: crumb.name, item: new URL(crumb.href, Astro.site).href };
  item["@type"] = "ListItem";
  return item;
});
const bcObj: Record<string, any> = { itemListElement: bcItems };
bcObj["@context"] = "https://schema.org";
bcObj["@type"] = "BreadcrumbList";
const breadcrumbJsonLd = JSON.stringify(bcObj);
---

{breadcrumbs.length > 1 && (
  <nav aria-label="Breadcrumb" class="px-4 sm:px-6 lg:px-8" style="background:rgba(6,8,15,0.8); border-bottom:1px solid rgba(255,255,255,0.05);">
    <div class="max-w-7xl mx-auto py-2.5">
      <ol class="flex items-center space-x-2 text-xs text-gray-500">
        {breadcrumbs.map((crumb, index) => (
          <li class="flex items-center">
            {index > 0 && (
              <svg class="h-3.5 w-3.5 mx-2" style="color:rgba(200,169,110,0.4);" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
            )}
            {index === breadcrumbs.length - 1 ? (
              <span class="font-medium" style="color:#c8a96e;" aria-current="page">
                {crumb.name}
              </span>
            ) : (
              <a
                href={crumb.href}
                class="text-gray-500 hover:text-gray-300 transition-colors"
                itemprop="item"
              >
                <span itemprop="name">{crumb.name}</span>
              </a>
            )}
            {index < breadcrumbs.length - 1 && (
              <meta itemprop="position" content={(index + 1).toString()} />
            )}
          </li>
        ))}
      </ol>
    </div>

    <!-- JSON-LD for Breadcrumbs -->
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </nav>
)}
