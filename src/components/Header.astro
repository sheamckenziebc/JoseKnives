---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';
import Breadcrumbs from './Breadcrumbs.astro';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 sticky top-0 z-50 transition-all duration-300" id="site-header">
  <!-- Top bar with contact info (desktop only) -->
  <div class="hidden lg:block bg-stone-900 text-white text-sm" id="top-bar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center py-2">
      <div class="flex items-center gap-6">
        <a href={`mailto:${config.contact.email}`} class="flex items-center gap-1.5 hover:text-amber-400 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          {config.contact.email}
        </a>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {config.contact.businessHours}
        </span>
      </div>
      <div class="flex items-center gap-4">
        {config.social.facebook && (
          <a href={config.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
          </a>
        )}
        {config.social.instagram && (
          <a href={config.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 lg:h-18">
      <!-- Logo -->
      <div class="flex items-center">
        <a href={base} class="flex items-center space-x-2 group" aria-label="Home">
          <img
            src={`${base}assets/logo.svg`}
            alt={`${config.site.title} logo`}
            class="h-9 w-auto transition-transform group-hover:scale-105"
            width="36"
            height="36"
          />
          <div class="flex flex-col">
            <span class="text-lg font-extrabold text-gray-900 leading-tight" style="font-family: 'Cormorant Garamond', serif;">{config.site.title}</span>
            <span class="text-[10px] text-gray-500 font-medium uppercase tracking-widest hidden sm:block">Custom Knives</span>
          </div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <ul class="flex items-center gap-1" role="menubar">
          <li role="none">
            <a
              href={base}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath === base || currentPath === base.slice(0, -1) ? 'bg-slate-100' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}
              style={currentPath === base || currentPath === base.slice(0, -1) ? 'color:#1c2a3a;' : ''}
            >
              Home
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}about/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'bg-slate-100' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}
              style={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'color:#1c2a3a;' : ''}
            >
              The Maker
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}gallery/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.includes('/gallery') ? 'bg-slate-100' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.includes('/gallery') ? 'page' : undefined}
              style={currentPath.includes('/gallery') ? 'color:#1c2a3a;' : ''}
            >
              Gallery
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}artwork/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.includes('/artwork') ? 'bg-slate-100' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.includes('/artwork') ? 'page' : undefined}
              style={currentPath.includes('/artwork') ? 'color:#1c2a3a;' : ''}
            >
              Custom Orders
            </a>
          </li>
          <li role="none">
            <a
              href={`${base}contact/`}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-all ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'bg-slate-100' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}
              role="menuitem"
              aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}
              style={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'color:#1c2a3a;' : ''}
            >
              Contact
            </a>
          </li>
        </ul>
        <!-- Desktop CTA -->
        <a
          href={`${base}contact/`}
          class="ml-4 inline-flex items-center bg-amber-600 text-white px-5 py-2.5 rounded-lg font-bold text-sm hover:bg-amber-500 transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5"
        >
          Commission a Knife
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center gap-3">
        <a href={`mailto:${config.contact.email}`} class="p-2" style="color:#1c2a3a;" aria-label="Email us">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
        <button
          type="button"
          class="text-gray-700 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 p-2 rounded-lg"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle mobile menu"
          id="mobile-menu-button"
        >
          <svg class="h-6 w-6 menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="h-6 w-6 close-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden overflow-hidden transition-all duration-300 max-h-0" id="mobile-menu">
      <div class="px-2 pt-2 pb-4 space-y-1 border-t border-gray-100">
        <a href={base} class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath === base || currentPath === base.slice(0, -1) ? 'bg-slate-100' : 'text-gray-700 hover:bg-gray-50'}`} style={currentPath === base || currentPath === base.slice(0, -1) ? 'color:#1c2a3a;' : ''} aria-current={currentPath === base || currentPath === base.slice(0, -1) ? 'page' : undefined}>Home</a>
        <a href={`${base}about/`} class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'bg-slate-100' : 'text-gray-700 hover:bg-gray-50'}`} style={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'color:#1c2a3a;' : ''} aria-current={currentPath.endsWith('/about') || currentPath.endsWith('/about/') ? 'page' : undefined}>The Maker</a>
        <a href={`${base}gallery/`} class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.includes('/gallery') ? 'bg-slate-100' : 'text-gray-700 hover:bg-gray-50'}`} style={currentPath.includes('/gallery') ? 'color:#1c2a3a;' : ''} aria-current={currentPath.includes('/gallery') ? 'page' : undefined}>Gallery</a>
        <a href={`${base}artwork/`} class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.includes('/artwork') ? 'bg-slate-100' : 'text-gray-700 hover:bg-gray-50'}`} style={currentPath.includes('/artwork') ? 'color:#1c2a3a;' : ''} aria-current={currentPath.includes('/artwork') ? 'page' : undefined}>Custom Orders</a>
        <a href={`${base}contact/`} class={`block px-4 py-3 text-base font-medium rounded-lg transition-all ${currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'bg-slate-100' : 'text-gray-700 hover:bg-gray-50'}`} style={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'color:#1c2a3a;' : ''} aria-current={currentPath.endsWith('/contact') || currentPath.endsWith('/contact/') ? 'page' : undefined}>Contact</a>
        <a href={`${base}contact/`} class="block mx-2 mt-3 text-center bg-amber-600 text-white px-4 py-3 rounded-lg font-bold hover:bg-amber-500 transition-colors">Commission a Knife</a>
      </div>
    </div>
  </div>

  <!-- Breadcrumbs (for non-home pages) -->
  {currentPath !== base && currentPath !== base.slice(0, -1) && <Breadcrumbs />}
</header>

<script>
  function initHeader() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = mobileMenuButton?.querySelector('.menu-icon');
    const closeIcon = mobileMenuButton?.querySelector('.close-icon');

    function closeMenu() {
      if (!mobileMenuButton || !mobileMenu) return;
      mobileMenuButton.setAttribute('aria-expanded', 'false');
      mobileMenu.style.maxHeight = '0';
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
        mobileMenuButton.setAttribute('aria-expanded', String(!isExpanded));
        if (isExpanded) {
          closeMenu();
        } else {
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });

      document.addEventListener('click', (e) => {
        if (mobileMenuButton.getAttribute('aria-expanded') === 'true'
            && !mobileMenu.contains(e.target as Node)
            && !mobileMenuButton.contains(e.target as Node)) {
          closeMenu();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenuButton.getAttribute('aria-expanded') === 'true') {
          closeMenu();
          mobileMenuButton.focus();
        }
      });

      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });
    }

    const header = document.getElementById('site-header');
    const topBar = document.getElementById('top-bar');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('shadow-md');
          topBar?.classList.add('hidden');
        } else {
          header.classList.remove('shadow-md');
          topBar?.classList.remove('hidden');
        }
      }, { passive: true });
    }
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
