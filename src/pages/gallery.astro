---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const items = [
  { file: "knife1.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife2.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife3.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife4.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife5.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife6.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife7.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "knife8.jpg", title: "[Product Title]", category: "knives", desc: "[Product Description Here]" },
  { file: "sword.jpg", title: "[Product Title]", category: "swords", desc: "[Product Description Here]" },
  { file: "sword2.jpg", title: "[Product Title]", category: "swords", desc: "[Product Description Here]" },
  { file: "axe.jpg", title: "[Product Title]", category: "swords", desc: "[Product Description Here]" },
  { file: "letteropener.jpg", title: "[Product Title]", category: "swords", desc: "[Product Description Here]" },
  { file: "leatherbags.jpg", title: "[Product Title]", category: "leather", desc: "[Product Description Here]" },
  { file: "sheaths.jpg", title: "[Product Title]", category: "leather", desc: "[Product Description Here]" },
  { file: "leatherboots.jpg", title: "[Product Title]", category: "apparel", desc: "[Product Description Here]" },
  { file: "bag.jpg", title: "[Product Title]", category: "apparel", desc: "[Product Description Here]" },
];

const categories = [
  { slug: "all", label: "All Work" },
  { slug: "knives", label: "Knives" },
  { slug: "swords", label: "Swords & Other Blades" },
  { slug: "leather", label: "Fine Leatherwork" },
  { slug: "apparel", label: "Apparel" },
];
---

<BaseLayout title={`Product Gallery | ${config.site.title}`} description="Browse handcrafted custom knives and fine leatherwork by J.M. Amoedo — chef's knives, hunting knives, collector's pieces and custom commissions.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative py-28 overflow-hidden" style="background:#0a0d14;">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 80% 50%, rgba(45,74,110,0.3) 0%, transparent 55%), radial-gradient(ellipse at 10% 70%, rgba(180,60,0,0.12) 0%, transparent 50%);"></div>
    <div class="absolute inset-0">
      <img src={`${base}assets/knife6.jpg`} alt="" class="w-full h-full object-cover opacity-15" aria-hidden="true" />
      <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(10,13,20,0.95) 0%,rgba(28,10,4,0.7) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="h-px w-10 opacity-60" style="background:#d4500a;"></div>
        <span class="text-xs font-bold uppercase tracking-[0.25em]" style="color:#d4500a;">Handcrafted Work</span>
        <div class="h-px w-10 opacity-60" style="background:#d4500a;"></div>
      </div>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif; letter-spacing:-0.02em;">
        Product <span style="background:linear-gradient(90deg,#c8a96e,#e8c98e,#c8a96e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Gallery</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed" style="font-weight:300;">
        Knives, leatherwork and custom commissions. Every piece is an original.
      </p>
    </div>
  </section>

  <!-- Wave: hero → steel -->
  <div class="-mb-1" style="background:#0a0d14;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 80L80 65C160 50 320 20 480 15C640 10 800 30 960 38C1120 46 1280 38 1360 34L1440 30V80H0Z" fill="#0f1923"/>
    </svg>
  </div>

  <!-- Gallery -->
  <section class="py-20" style="background:#0f1923;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Category Filter -->
      <div class="flex flex-wrap gap-3 justify-center mb-14">
        {categories.map(cat => (
          <button
            class="gallery-filter-btn px-6 py-2.5 rounded-full font-semibold text-xs uppercase tracking-widest transition-all"
            data-category={cat.slug}
            style={cat.slug === 'all'
              ? 'background:#d4500a; color:white; border:1px solid #d4500a;'
              : 'background:rgba(255,255,255,0.05); color:#9ca3af; border:1px solid rgba(255,255,255,0.1);'}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Image Grid -->
      <div class="columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4" id="gallery-grid">
        {items.map((item, i) => (
          <div
            class="gallery-item group break-inside-avoid overflow-hidden rounded-2xl cursor-pointer relative block"
            data-category={item.category}
            style="background:#1c2a3a;"
          >
            <img
              src={`${base}assets/${item.file}`}
              alt={`${item.title} by J.M. Amoedo`}
              class={`w-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-85 group-hover:opacity-100 ${i % 3 === 0 ? 'h-72' : i % 3 === 1 ? 'h-56' : 'h-64'}`}
              loading="lazy"
              onerror="this.parentElement.style.display='none';"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 flex items-end opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl overflow-hidden" style="background:linear-gradient(to top, rgba(10,13,20,0.92) 0%, rgba(10,13,20,0.3) 50%, transparent 100%);">
              <div class="p-4 w-full">
                <p class="text-white font-semibold text-sm mb-1" style="font-family:'Cormorant Garamond',serif;">{item.title}</p>
                <p class="text-gray-400 text-xs">{item.desc}</p>
              </div>
            </div>
            <!-- Category pill -->
            <div class="absolute top-3 left-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-full" style="background:rgba(212,80,10,0.85); color:white;">
                {categories.find(c => c.slug === item.category)?.label.split(' ')[0]}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave: steel → mahogany -->
  <div class="-mb-1" style="background:#0f1923;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 0L80 15C160 30 320 60 480 65C640 70 800 50 960 42C1120 34 1280 42 1360 46L1440 50V0H0Z" fill="#1c0a04"/>
    </svg>
  </div>

  <!-- Ordering Info -->
  <section class="py-24" style="background:#1c0a04;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="flex items-center justify-center gap-3 mb-5 animate-on-scroll">
          <div class="h-px w-8 opacity-60" style="background:#c8a96e;"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#c8a96e;">Ordering</span>
          <div class="h-px w-8 opacity-60" style="background:#c8a96e;"></div>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2 mb-4 animate-on-scroll" style="font-family:'Cormorant Garamond',serif;">
          Interested in a Custom Piece?
        </h2>

        <div class="mt-10 rounded-3xl p-8 md:p-10 text-left animate-on-scroll" style="background:rgba(255,255,255,0.04); border:1px solid rgba(200,169,110,0.15);">
          <p class="text-gray-300 leading-relaxed mb-5">
            Any style shown can be adapted to your specifications — different steel, handle material, blade length or leatherwork design. Pieces not shown are also possible; just describe what you have in mind.
          </p>
          <p class="text-gray-300 leading-relaxed mb-6">
            To start a commission or ask about availability:
          </p>
          <a href={`mailto:${config.contact.email}`} class="inline-flex items-center gap-2 font-semibold transition-all hover:gap-4" style="color:#c8a96e;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {config.contact.email}
          </a>
          <p class="text-sm text-gray-500 italic mt-6">
            All pieces are made to order. Lead time varies. Get in touch to discuss your project.
          </p>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
          <a href={`${base}contact/`} class="inline-flex items-center justify-center text-white px-9 py-4 rounded-xl font-bold tracking-wide transition-all hover:-translate-y-0.5" style="background:#d4500a; box-shadow:0 0 30px rgba(212,80,10,0.2);">
            Send an Inquiry
          </a>
          <a href={`${base}artwork/`} class="inline-flex items-center justify-center px-9 py-4 rounded-xl font-semibold tracking-wide transition-all hover:bg-white/5" style="border:1px solid rgba(200,169,110,0.35); color:#c8a96e;">
            How It Works
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  function initGalleryFilter() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.gallery-filter-btn');
    const items = document.querySelectorAll<HTMLElement>('.gallery-item');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.dataset.category;
        buttons.forEach(b => {
          b.style.background = 'rgba(255,255,255,0.05)';
          b.style.color = '#9ca3af';
          b.style.border = '1px solid rgba(255,255,255,0.1)';
        });
        btn.style.background = '#d4500a';
        btn.style.color = 'white';
        btn.style.border = '1px solid #d4500a';

        items.forEach(item => {
          item.style.display = (category === 'all' || item.dataset.category === category) ? 'block' : 'none';
        });
      });
    });
  }
  document.addEventListener('astro:page-load', initGalleryFilter);
</script>
