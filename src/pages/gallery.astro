---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const categories = [
  { name: "Serving & Baking", slug: "serving", description: "Platters, bowls, baking dishes and serving ware for everyday use and special occasions." },
  { name: "Storage Pots", slug: "storage", description: "Lidded jars, canisters and storage vessels for kitchen and home." },
  { name: "Vases", slug: "vases", description: "Decorative and functional vases in various sizes and glazes." },
  { name: "Drinking", slug: "drinking", description: "Mugs, cups, teapots and drinking vessels for your daily rituals." },
  { name: "Other", slug: "other", description: "Sculptures, masks, jewelry, wall murals, tiles, sinks, clocks and lamps." },
  { name: "Custom Orders", slug: "custom", description: "Combining form, colour and images in unique ways to suit your interests." }
];
---

<BaseLayout title={`Pottery Gallery | ${config.site.title}`} description="Browse handmade pottery by Franziska Cody — serving ware, storage pots, vases, mugs and custom pieces. All food, microwave and oven safe.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-stone-900 via-red-900 to-stone-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">Handmade Pottery</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
        Pottery <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">Gallery</span>
      </h1>
      <p class="text-xl text-red-100 max-w-3xl mx-auto leading-relaxed">
        All pieces shown represent an assortment of what is offered by Art and Soul Pottery. Additionally, I can create custom items, combining form, colour and images in unique ways to suit your interests.
      </p>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-stone-900 via-red-900 to-stone-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Gallery Categories -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-red-800 font-semibold text-sm uppercase tracking-wider">Browse by Category</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          Pottery Collections
        </h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {categories.map((cat) => (
          <div class="animate-on-scroll group bg-stone-50 rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="h-48 bg-gradient-to-br from-red-100 to-amber-100 flex items-center justify-center relative overflow-hidden">
              <img
                src={`${base}assets/gallery-${cat.slug}.jpg`}
                alt={`${cat.name} pottery by Franziska Cody`}
                class="w-full h-full object-cover"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="hidden items-center justify-center absolute inset-0 bg-gradient-to-br from-red-100 to-amber-100">
                <svg class="w-16 h-16 text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
              <div class="absolute top-3 right-3 bg-white/90 text-xs font-bold text-gray-700 px-2 py-1 rounded-full">{cat.name}</div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2" style="font-family: 'Cormorant Garamond', serif;">{cat.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{cat.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ordering Info -->
  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center animate-on-scroll">
        <span class="text-red-800 font-semibold text-sm uppercase tracking-wider">How to Order</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
          Purchase & Custom Orders
        </h2>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-left space-y-4">
          <p class="text-gray-600 leading-relaxed">
            You are also welcome to request designs not shown on the website. Art and Soul Pottery will then create a one of a kind piece(s) using your personal logo/image.
          </p>
          <p class="text-gray-600 leading-relaxed">
            To purchase artwork please contact Art and Soul Pottery at:
          </p>
          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
            <a href={`tel:${config.contact.phone}`} class="inline-flex items-center text-red-800 font-semibold hover:text-red-900 transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {config.contact.phone}
            </a>
            <a href={`mailto:${config.contact.email}`} class="inline-flex items-center text-red-800 font-semibold hover:text-red-900 transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {config.contact.email}
            </a>
          </div>
          <p class="text-sm text-gray-500 italic">
            All orders require a min. turn around period of one month, or inquire in store about availability of pottery. All prices are in Canadian dollars, applicable taxes are added additionally.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
