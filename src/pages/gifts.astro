---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const tips = [
  {
    title: "Wash by hand",
    desc: "Never put a handmade knife in the dishwasher. Hot water, detergent and machine action are hard on handles and can cause steel to rust or discolour. Wash with warm soapy water and dry immediately."
  },
  {
    title: "Dry completely before storing",
    desc: "Don't leave a wet knife sitting out or in a damp drawer. Moisture causes rust on carbon steel especially. Dry thoroughly with a cloth after washing."
  },
  {
    title: "Use a proper cutting surface",
    desc: "Wood and plastic cutting boards are fine. Glass, ceramic, stone and metal surfaces will roll or chip the edge. Don't cut on plates or countertops."
  },
  {
    title: "Sharpen regularly",
    desc: "A sharp knife is safer and easier to use than a dull one. Use a quality whetstone or have it professionally sharpened. Hone on a leather strop between sharpenings to maintain the edge."
  },
  {
    title: "Oil carbon steel blades",
    desc: "Carbon steel will develop a patina with use — this is normal and actually helps protect the blade. A light coat of food-safe oil (mineral oil or camellia oil) keeps it protected during storage."
  },
  {
    title: "Store safely",
    desc: "Use a knife block, magnetic strip or blade guard. Loose knives in a drawer bang against other utensils and damage the edge. Never store in a sheath long-term as moisture can be trapped against the blade."
  },
  {
    title: "Oil wooden handles",
    desc: "Natural wood handles benefit from occasional oiling with food-safe mineral oil or linseed oil. Rub in, let it soak, wipe off the excess. This prevents drying and cracking."
  },
  {
    title: "Get it re-sharpened when needed",
    desc: "If a knife won't take a good edge with home sharpening, it may need professional attention. Reach out — I'm happy to sharpen knives I've made."
  }
];
---

<BaseLayout title={`Knife Care | ${config.site.title}`} description="How to care for your J.M. Amoedo custom knife — washing, drying, sharpening, oiling and storage tips to keep your blade performing for a lifetime.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative py-24 overflow-hidden" style="background-color:#0f1923;">
    <div class="absolute inset-0">
      <img
        src={`${base}assets/knife-04.jpg`}
        alt="Caring for your custom knife"
        class="w-full h-full object-cover opacity-20"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,25,35,0.92) 0%, rgba(28,42,58,0.75) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="font-semibold text-sm uppercase tracking-wider mb-4 block" style="color:#c8a96e;">Maintenance Guide</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
        Knife <span style="background: linear-gradient(90deg, #c8a96e, #e8c98e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Care</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        A handmade knife will last a lifetime with basic care. Here's how to look after it.
      </p>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="-mb-1" style="background-color:#0f1923;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Care Tips -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">Care & Maintenance</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          Keep Your Blade at Its Best
        </h2>
        <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children">
        {tips.map(tip => (
          <div class="animate-on-scroll bg-white rounded-3xl p-6 shadow-sm border border-gray-100 card-hover">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color:#fef3c7;">
                <svg class="w-4 h-4" style="color:#c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-2">{tip.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{tip.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Questions CTA -->
  <section class="py-20" style="background-color:#1c2a3a;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4" style="font-family: 'Cormorant Garamond', serif;">
        Questions About Your Knife?
      </h2>
      <p class="text-gray-300 mb-8 text-lg">
        Get in touch — I'm happy to advise on care, sharpening or any issues with a knife I've made.
      </p>
      <a href={`${base}contact/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-amber-500 transition-all shadow-lg">
        Contact Me
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
