---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const tips = [
  { title: "Wash by hand", desc: "Never put a handmade knife in the dishwasher. Wash with warm soapy water and dry immediately. Hot water and detergent are hard on handles and will cause carbon steel to rust." },
  { title: "Dry completely before storing", desc: "Moisture causes rust, especially on carbon steel. Dry thoroughly with a cloth after every wash before storing." },
  { title: "Use a proper cutting surface", desc: "Wood and plastic cutting boards only. Glass, ceramic, stone and metal will roll or chip the edge. Never cut on plates or countertops." },
  { title: "Sharpen regularly", desc: "A sharp knife is safer than a dull one. Use a quality whetstone and hone on a leather strop between sharpenings to maintain the edge." },
  { title: "Oil carbon steel blades", desc: "Carbon steel develops a patina — this is normal and protective. A light coat of food-safe mineral or camellia oil keeps it protected in storage." },
  { title: "Store safely", desc: "Knife block, magnetic strip or blade guard. Loose knives in drawers damage the edge. Don't store long-term in a sheath as moisture can be trapped against the blade." },
  { title: "Oil wooden handles", desc: "Natural wood handles benefit from occasional food-safe mineral oil. Rub in, let soak, wipe off the excess. Prevents drying and cracking." },
  { title: "Condition leather sheaths", desc: "Leather sheaths should be conditioned periodically with a quality leather conditioner or neatsfoot oil. This prevents drying, cracking and staining." },
];
---

<BaseLayout title={`Knife Care | ${config.site.title}`} description="How to care for your J.M. Amoedo custom knife and leatherwork — washing, drying, sharpening, oiling and storage.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative py-28 overflow-hidden" style="background:#0a0d14;">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at 20% 50%, rgba(180,60,0,0.13) 0%, transparent 55%), radial-gradient(ellipse at 80% 30%, rgba(45,74,110,0.25) 0%, transparent 50%);"></div>
    <div class="absolute inset-0">
      <img src={`${base}assets/knife4.jpg`} alt="" class="w-full h-full object-cover opacity-15" aria-hidden="true" />
      <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(10,13,20,0.95) 0%,rgba(28,10,4,0.65) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="h-px w-10 opacity-60" style="background:#c8a96e;"></div>
        <span class="text-xs font-bold uppercase tracking-[0.25em]" style="color:#c8a96e;">Maintenance Guide</span>
        <div class="h-px w-10 opacity-60" style="background:#c8a96e;"></div>
      </div>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mt-2 mb-6" style="font-family:'Cormorant Garamond',serif; letter-spacing:-0.02em;">
        Knife & Leather <span style="background:linear-gradient(90deg,#c8a96e,#e8c98e,#c8a96e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Care</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed" style="font-weight:300;">
        A handmade piece will last a lifetime with basic care. Here's how to look after it.
      </p>
    </div>
  </section>

  <!-- Wave: hero → steel -->
  <div class="-mb-1" style="background:#0a0d14;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 80L80 65C160 50 320 20 480 15C640 10 800 30 960 38C1120 46 1280 38 1360 34L1440 30V80H0Z" fill="#0f1923"/>
    </svg>
  </div>

  <!-- Care Tips — steel -->
  <section class="py-24" style="background:#0f1923;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="h-px w-8 opacity-60" style="background:#d4500a;"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#d4500a;">Care & Maintenance</span>
          <div class="h-px w-8 opacity-60" style="background:#d4500a;"></div>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family:'Cormorant Garamond',serif;">Keep Your Piece at Its Best</h2>
        <div class="mt-5 h-0.5 w-20 mx-auto opacity-30" style="background:linear-gradient(90deg,transparent,#c8a96e,transparent);"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 stagger-children">
        {tips.map(tip => (
          <div class="animate-on-scroll group flex gap-5 p-7 rounded-3xl transition-all duration-300 hover:-translate-y-0.5" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(200,169,110,0.1); border:1px solid rgba(200,169,110,0.2);">
              <svg class="w-4 h-4" style="color:#c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-white mb-2 text-base">{tip.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{tip.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave: steel → near-black -->
  <div class="-mb-1" style="background:#0f1923;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 0L80 15C160 30 320 60 480 65C640 70 800 50 960 42C1120 34 1280 42 1360 46L1440 50V0H0Z" fill="#0a0d14"/>
    </svg>
  </div>

  <!-- CTA — near-black with fire -->
  <section class="relative py-20 overflow-hidden" style="background:#0a0d14;">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at 50% 100%, rgba(212,80,10,0.14) 0%, transparent 60%);"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family:'Cormorant Garamond',serif;">
        Questions About Your Piece?
      </h2>
      <p class="text-gray-400 mb-8 text-lg" style="font-weight:300;">
        Get in touch — I'm happy to advise on care, sharpening or any issues.
      </p>
      <a href={`${base}contact/`} class="inline-flex items-center justify-center text-white px-9 py-4 rounded-xl font-bold tracking-wide transition-all hover:-translate-y-0.5" style="background:#d4500a; box-shadow:0 0 30px rgba(212,80,10,0.2);">
        Contact Me
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
