---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const aboutLogoUrl = new URL(config.branding.logo, Astro.site).href;
const contactPt: Record<string, any> = { contactType: "Customer Service", email: config.contact.email };
contactPt["@type"] = "ContactPoint";
const mainEntity: Record<string, any> = { name: config.site.title, description: config.site.description, url: config.site.url, logo: aboutLogoUrl, contactPoint: contactPt };
mainEntity["@type"] = "Organization";
const aboutObj: Record<string, any> = { mainEntity };
aboutObj["@context"] = "https://schema.org";
aboutObj["@type"] = "AboutPage";
const aboutJsonLd = JSON.stringify(aboutObj);
---

<BaseLayout title={`The Maker | ${config.site.title}`} description="Meet J.M. Amoedo — custom knife maker. Each blade is forged by hand, shaped from raw steel and built to last a lifetime.">
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative py-24 overflow-hidden" style="background-color:#0f1923;">
    <div class="absolute inset-0">
      <img
        src={`${base}assets/knife-12.jpg`}
        alt="J.M. Amoedo at work in the forge"
        class="w-full h-full object-cover opacity-25"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,25,35,0.9) 0%, rgba(28,42,58,0.7) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="font-semibold text-sm uppercase tracking-wider mb-4 block" style="color:#c8a96e;">The Maker</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
          J.M. <span style="background: linear-gradient(90deg, #c8a96e, #e8c98e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Amoedo</span>
        </h1>
        <p class="text-xl text-gray-300 leading-relaxed">
          Custom knife maker. Each blade is forged by hand — shaped from raw steel and built to perform for a lifetime.
        </p>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="-mb-1" style="background-color:#0f1923;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Maker's Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">
        <div class="animate-on-scroll">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6" style="font-family: 'Cormorant Garamond', serif;">
            The Story Behind the Blades
          </h2>
          <div class="space-y-5 text-gray-600 text-lg leading-relaxed">
            <p>
              J.M. Amoedo is a custom knife maker driven by a deep respect for the craft of blade making. Every knife that leaves the workshop is built from raw materials, shaped by hand, and tested before it goes out the door.
            </p>
            <p>
              The work starts at the forge — raw steel drawn out, shaped under heat and hammer, then ground to geometry on the wheel. Handles are fitted from a range of natural materials: hardwoods, stabilized burls, bone, horn and brass, chosen for the knife and the person who'll carry it.
            </p>
            <p>
              The goal with every blade is the same: a knife that feels right in the hand, holds an edge, and gets better with use.
            </p>
          </div>
        </div>
        <div class="relative animate-on-scroll">
          <img
            src={`${base}assets/knife-13.jpg`}
            alt="Detail of a J.M. Amoedo custom knife"
            class="rounded-3xl shadow-xl w-full h-auto object-cover"
            loading="lazy"
            onerror="this.src=''; this.style.display='none';"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- The Craft -->
  <section class="py-20" style="background-color:#f5f1e8;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12 animate-on-scroll">
          <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">Craft & Philosophy</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
            Materials & Method
          </h2>
          <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
          {[
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>`,
              title: "Steel",
              desc: "High-carbon and stainless steels selected for their performance characteristics — hardness, toughness, edge retention and corrosion resistance."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>`,
              title: "Handle Materials",
              desc: "Stabilized hardwoods, natural burls, bone, horn, antler and brass. Each handle material is chosen for how it looks, how it ages and how it feels in use."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
              title: "Finishing",
              desc: "Each blade is hand-sanded through progressive grits, heat-treated to specification, then finished to a consistent edge before fitting and final assembly."
            }
          ].map(item => (
            <div class="animate-on-scroll bg-white rounded-3xl p-8 shadow-sm border border-gray-100 card-hover">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 card-icon" style="background-color:#e8f0f8;">
                <svg class="w-7 h-7" style="color:#1c2a3a;" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">The Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          Recent Pieces
        </h2>
        <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 stagger-children">
        {[14,15,16,1,2,3].map((n) => (
          <div class="animate-on-scroll overflow-hidden rounded-2xl aspect-square bg-gray-100">
            <img
              src={`${base}assets/knife-${String(n).padStart(2,'0')}.jpg`}
              alt="Custom knife by J.M. Amoedo"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.parentElement.style.display='none';"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 overflow-hidden" style="background-color:#1c2a3a;">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: 'Cormorant Garamond', serif;">
        Commission Your Knife
      </h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Get in touch to discuss what you have in mind. Every knife starts with a conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}gallery/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-amber-500 transition-all shadow-lg">
          View Gallery
        </a>
        <a href={`${base}contact/`} class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/10 transition-all">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={aboutJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
