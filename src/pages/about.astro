---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const aboutLogoUrl = new URL(config.branding.logo, Astro.site).href;
const contactPt: Record<string, any> = { contactType: "Customer Service", email: config.contact.email };
contactPt["@type"] = "ContactPoint";
const mainEntity: Record<string, any> = { name: config.site.title, description: config.site.description, url: config.site.url, logo: aboutLogoUrl, contactPoint: contactPt };
mainEntity["@type"] = "Organization";
const aboutObj: Record<string, any> = { mainEntity };
aboutObj["@context"] = "https://schema.org";
aboutObj["@type"] = "AboutPage";
const aboutJsonLd = JSON.stringify(aboutObj);
---

<BaseLayout title={`The Maker | ${config.site.title}`} description="Meet J.M. Amoedo — custom knife maker and leatherworker. Each piece is built from raw materials, finished by hand, and made to last a lifetime.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative py-28 overflow-hidden" style="background:#0a0d14;">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at 20% 60%, rgba(180,60,0,0.16) 0%, transparent 55%), radial-gradient(ellipse at 80% 20%, rgba(45,74,110,0.3) 0%, transparent 50%);"></div>
    <div class="absolute inset-0">
      <img src={`${base}assets/knife-12.jpg`} alt="" class="w-full h-full object-cover opacity-18" aria-hidden="true" />
      <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(10,13,20,0.95) 0%,rgba(28,10,4,0.6) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="h-px w-10 opacity-60" style="background:#c8a96e;"></div>
        <span class="text-xs font-bold uppercase tracking-[0.25em]" style="color:#c8a96e;">The Maker</span>
        <div class="h-px w-10 opacity-60" style="background:#c8a96e;"></div>
      </div>
      <h1 class="text-5xl md:text-6xl lg:text-8xl font-bold text-white mt-2 mb-6" style="font-family:'Cormorant Garamond',serif; letter-spacing:-0.02em;">
        J.M. <span style="background:linear-gradient(90deg,#c8a96e,#e8c98e,#c8a96e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Amoedo</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed" style="font-weight:300;">
        Custom knife maker and leatherworker. Every piece built from raw materials, finished by hand.
      </p>
    </div>
  </section>

  <!-- Wave: hero → mahogany -->
  <div class="-mb-1" style="background:#0a0d14;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 80L80 65C160 50 320 20 480 15C640 10 800 30 960 38C1120 46 1280 38 1360 34L1440 30V80H0Z" fill="#1c0a04"/>
    </svg>
  </div>

  <!-- Story — mahogany -->
  <section class="py-24" style="background:#1c0a04;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="animate-on-scroll">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 opacity-60" style="background:#d4500a;"></div>
            <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#d4500a;">The Story</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 leading-tight" style="font-family:'Cormorant Garamond',serif;">
            The Story Behind<br />the Blades
          </h2>
          <div class="space-y-5 text-gray-400 text-lg leading-relaxed" style="font-weight:300;">
            <p>
              J.M. Amoedo is a custom knife maker and leatherworker driven by a deep respect for the craft of working with raw materials. Every piece that leaves the workshop is built from the ground up, shaped by hand, and tested before it goes out the door.
            </p>
            <p>
              The blade work starts at the forge — raw steel drawn out under heat and hammer, then ground to geometry, heat-treated and hand-finished. Handles are fitted from natural materials: hardwoods, stabilized burls, bone, horn and brass, each chosen for the knife and the person who will carry it.
            </p>
            <p>
              The leatherwork follows the same philosophy — oil-tanned hides, saddle-stitched by hand, built to age beautifully and last a lifetime.
            </p>
            <p>
              The goal with every piece is the same: something that feels right, performs well, and gets better with use.
            </p>
          </div>
        </div>
        <div class="relative animate-on-scroll">
          <div class="absolute -inset-4 rounded-3xl opacity-20 blur-2xl" style="background:radial-gradient(ellipse, rgba(212,80,10,0.4), transparent 70%);"></div>
          <img
            src={`${base}assets/knife-13.jpg`}
            alt="Detail of a J.M. Amoedo custom knife"
            class="relative rounded-3xl shadow-2xl w-full h-auto object-cover"
            loading="lazy"
            onerror="this.style.display='none';"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: mahogany → steel -->
  <div class="-mb-1" style="background:#1c0a04;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 0L80 15C160 30 320 60 480 65C640 70 800 50 960 42C1120 34 1280 42 1360 46L1440 50V0H0Z" fill="#0f1923"/>
    </svg>
  </div>

  <!-- Materials & Method — steel -->
  <section class="py-24" style="background:#0f1923;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="h-px w-8 opacity-60" style="background:#c8a96e;"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#c8a96e;">Craft & Philosophy</span>
          <div class="h-px w-8 opacity-60" style="background:#c8a96e;"></div>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family:'Cormorant Garamond',serif;">Materials & Method</h2>
        <div class="mt-5 h-0.5 w-20 mx-auto opacity-30" style="background:linear-gradient(90deg,transparent,#c8a96e,transparent);"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>`,
            title: "Steel",
            desc: "High-carbon and stainless steels selected for hardness, toughness, edge retention and corrosion resistance — matched to the knife's intended purpose."
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>`,
            title: "Handles & Leather",
            desc: "Stabilized hardwoods, natural burls, bone, horn, antler and brass for handles. Full-grain and oil-tanned hides for leather goods — chosen for how they look, age and feel."
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
            title: "Finishing",
            desc: "Each blade is hand-sanded through progressive grits, heat-treated to specification, and sharpened before leaving the workshop. Leather goods are burnished, conditioned and saddle-stitched."
          }
        ].map(item => (
          <div class="animate-on-scroll group relative overflow-hidden rounded-3xl p-8 transition-all duration-300 hover:-translate-y-1" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background:radial-gradient(ellipse at 50% 0%, rgba(200,169,110,0.08), transparent 70%);"></div>
            <div class="relative">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background:rgba(212,80,10,0.12); border:1px solid rgba(212,80,10,0.2);">
                <svg class="w-6 h-6" style="color:#d4500a;" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
              </div>
              <h3 class="text-xl font-bold text-white mb-4" style="font-family:'Cormorant Garamond',serif;">{item.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave: steel → mahogany -->
  <div class="-mb-1" style="background:#0f1923;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 80L80 65C160 50 320 20 480 15C640 10 800 30 960 38C1120 46 1280 38 1360 34L1440 30V80H0Z" fill="#1c0a04"/>
    </svg>
  </div>

  <!-- Photo Grid — mahogany -->
  <section class="py-24" style="background:#1c0a04;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="h-px w-8 opacity-60" style="background:#d4500a;"></div>
          <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#d4500a;">The Work</span>
          <div class="h-px w-8 opacity-60" style="background:#d4500a;"></div>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mt-2" style="font-family:'Cormorant Garamond',serif;">Recent Pieces</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 stagger-children">
        {[14,15,16,1,2,3].map((n) => (
          <div class="animate-on-scroll overflow-hidden rounded-2xl aspect-square" style="background:#0f1923;">
            <img
              src={`${base}assets/knife-${String(n).padStart(2,'0')}.jpg`}
              alt="Custom work by J.M. Amoedo"
              class="w-full h-full object-cover hover:scale-110 transition-transform duration-700 opacity-80 hover:opacity-100"
              loading="lazy"
              onerror="this.parentElement.style.display='none';"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — near black with fire -->
  <section class="relative py-24 overflow-hidden" style="background:#0a0d14;">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at 50% 100%, rgba(212,80,10,0.16) 0%, transparent 60%);"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-5" style="font-family:'Cormorant Garamond',serif;">
        Commission Your Piece
      </h2>
      <p class="text-xl text-gray-400 mb-10" style="font-weight:300;">
        Knife or leather — get in touch to discuss what you have in mind.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}gallery/`} class="inline-flex items-center justify-center text-white px-9 py-4 rounded-xl font-bold tracking-wide transition-all hover:-translate-y-0.5" style="background:#d4500a; box-shadow:0 0 30px rgba(212,80,10,0.2);">
          View Gallery
        </a>
        <a href={`${base}contact/`} class="inline-flex items-center justify-center px-9 py-4 rounded-xl font-semibold tracking-wide transition-all hover:bg-white/5" style="border:1px solid rgba(200,169,110,0.35); color:#c8a96e;">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={aboutJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
