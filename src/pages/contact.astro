---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const cContactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email, availableLanguage: ["English", "German"] };
cContactPt["@type"] = "ContactPoint";
const cAddr: Record<string, any> = { streetAddress: "1269 Hwy 16", addressLocality: "Telkwa", addressRegion: "BC", postalCode: "V0J 2X0", addressCountry: "CA" };
cAddr["@type"] = "PostalAddress";
const cMainEntity: Record<string, any> = { name: config.site.title, contactPoint: cContactPt, address: cAddr };
cMainEntity["@type"] = "Organization";
const contactObj: Record<string, any> = { mainEntity: cMainEntity };
contactObj["@context"] = "https://schema.org";
contactObj["@type"] = "ContactPage";
const contactJsonLd = JSON.stringify(contactObj);

const mapLat = config.integrations.map_coordinates.lat;
const mapLng = config.integrations.map_coordinates.lng;
const mapTitle = config.site.title;
const mapAddress = config.contact.address;
---

<BaseLayout title={`Contact | ${config.site.title}`} description={`Contact Art and Soul Pottery in Telkwa, BC. Call ${config.contact.phone} or email ${config.contact.email}. Open Mon, Wed & Thurs 10am-5pm.`}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-stone-900 via-red-900 to-stone-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">Get In Touch</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
        Contact <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">Us</span>
      </h1>
      <p class="text-xl text-red-100 max-w-3xl mx-auto leading-relaxed">
        Visit the studio, inquire about custom orders, or get in touch about commissions and projects.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-gray-900 mb-2" style="font-family: 'Cormorant Garamond', serif;">Send a Message</h2>
          <p class="text-gray-500 mb-8">Fill out the form below to contact me about commissions and projects. I will respond as soon as possible.</p>

          <form
            action={`https://formspree.io/f/${config.integrations.formspree_id}`}
            method="POST"
            class="space-y-6"
            id="contact-form"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Your Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-colors" placeholder="Your name" autocomplete="name" />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-colors" placeholder="your@email.com" autocomplete="email" />
            </div>

            <div>
              <label for="inquiry-type" class="block text-sm font-medium text-gray-700 mb-2">Inquiry Type</label>
              <select id="inquiry-type" name="inquiry-type" class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-colors">
                <option value="">What can I help you with?</option>
                <option value="custom-order">Custom Pottery Order</option>
                <option value="purchase">Purchase Inquiry</option>
                <option value="studio-visit">Studio Visit</option>
                <option value="commission">Art Commission</option>
                <option value="wholesale">Wholesale / Gallery</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message *</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-colors" placeholder="Tell me about what you're looking for..."></textarea>
            </div>

            <input type="text" name="_gotcha" style="display:none" />

            <button type="submit" class="w-full bg-red-800 text-white py-3.5 px-6 rounded-lg font-semibold text-lg hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
              Send Message
            </button>
          </form>

          <div id="form-status" class="mt-4 p-4 rounded-md hidden" aria-live="polite" role="status">
            <p id="form-message"></p>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-gray-900 mb-2" style="font-family: 'Cormorant Garamond', serif;">Visit the Studio</h2>
          <p class="text-gray-500 mb-8">Located on Highway 16 in Telkwa, in the heart of the Bulkley Valley.</p>

          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Address</h3>
                <p class="text-gray-600">{config.contact.address}</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Phone</h3>
                <a href={`tel:${config.contact.phone}`} class="text-red-800 hover:text-red-900 transition-colors">{config.contact.phone}</a>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Email</h3>
                <a href={`mailto:${config.contact.email}`} class="text-red-800 hover:text-red-900 transition-colors">{config.contact.email}</a>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-red-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Hours</h3>
                <p class="text-gray-600">Monday, Wednesday & Thursday: 10am — 5pm</p>
                <p class="text-gray-400 text-sm italic">All other days by appointment</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="py-12 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4" style="font-family: 'Cormorant Garamond', serif;">Find Us</h2>
        <p class="text-xl text-gray-600">1269 Hwy 16, Telkwa, BC — in the heart of the Bulkley Valley</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div id="map" class="h-96 w-full bg-gray-200 flex items-center justify-center">
          <div class="text-center">
            <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <p class="text-gray-500">Interactive Map</p>
            <p class="text-sm text-gray-400 mt-2">{config.contact.address}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={contactJsonLd} />
  <div id="map-data" data-lat={mapLat} data-lng={mapLng} data-title={mapTitle} data-address={mapAddress} style="display:none;"></div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formStatus = document.getElementById('form-status');
    const formMessage = document.getElementById('form-message');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Sending...';
        }
        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, { method: 'POST', body: formData, headers: { 'Accept': 'application/json' } });
          if (response.ok) {
            formStatus!.className = 'mt-4 p-4 rounded-md bg-green-50 border border-green-200';
            formMessage!.textContent = 'Thank you for your message! I will respond as soon as possible.';
            formMessage!.className = 'text-green-800 font-medium';
            form.reset();
          } else { throw new Error('Form submission failed'); }
        } catch {
          formStatus!.className = 'mt-4 p-4 rounded-md bg-red-50 border border-red-200';
          formMessage!.textContent = 'Sorry, there was an error. Please try again or call us directly.';
          formMessage!.className = 'text-red-800 font-medium';
        }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Message'; }
        formStatus!.classList.remove('hidden');
      });
    }

    const mapContainer = document.getElementById('map');
    if (mapContainer) {
      const mapObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            mapObserver.unobserve(entry.target);
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
            document.head.appendChild(link);
            const script = document.createElement('script');
            script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
            script.onload = () => {
              const mapData = document.getElementById('map-data');
              if (!mapData) return;
              const lat = parseFloat(mapData.dataset.lat || '0');
              const lng = parseFloat(mapData.dataset.lng || '0');
              const title = mapData.dataset.title || '';
              const address = mapData.dataset.address || '';
              const map = (window as any).L.map('map').setView([lat, lng], 15);
              (window as any).L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>' }).addTo(map);
              (window as any).L.marker([lat, lng]).addTo(map).bindPopup('<b>' + title + '</b><br>' + address).openPopup();
            };
            document.body.appendChild(script);
          }
        });
      }, { rootMargin: '200px' });
      mapObserver.observe(mapContainer);
    }
  </script>

  <Footer slot="footer" />
</BaseLayout>
