---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const cContactPt: Record<string, any> = { contactType: "Customer Service", email: config.contact.email };
cContactPt["@type"] = "ContactPoint";
const cMainEntity: Record<string, any> = { name: config.site.title, contactPoint: cContactPt };
cMainEntity["@type"] = "Organization";
const contactObj: Record<string, any> = { mainEntity: cMainEntity };
contactObj["@context"] = "https://schema.org";
contactObj["@type"] = "ContactPage";
const contactJsonLd = JSON.stringify(contactObj);
---

<BaseLayout title={`Contact | ${config.site.title}`} description={`Commission a custom knife or leather piece from J.M. Amoedo. Get in touch at ${config.contact.email}.`}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative py-28 overflow-hidden" style="background:#0a0d14;">
    <div class="absolute inset-0" style="background:radial-gradient(ellipse at 70% 50%, rgba(180,60,0,0.14) 0%, transparent 55%), radial-gradient(ellipse at 20% 20%, rgba(45,74,110,0.25) 0%, transparent 50%);"></div>
    <div class="absolute inset-0">
      <img src={`${base}assets/leatherbags.jpg`} alt="" class="w-full h-full object-cover opacity-15" aria-hidden="true" />
      <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(10,13,20,0.95) 0%,rgba(28,10,4,0.65) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="h-px w-10 opacity-60" style="background:#d4500a;"></div>
        <span class="text-xs font-bold uppercase tracking-[0.25em]" style="color:#d4500a;">Start a Commission</span>
        <div class="h-px w-10 opacity-60" style="background:#d4500a;"></div>
      </div>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mt-2 mb-6" style="font-family:'Cormorant Garamond',serif; letter-spacing:-0.02em;">
        Get in <span style="background:linear-gradient(90deg,#c8a96e,#e8c98e,#c8a96e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Touch</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed" style="font-weight:300;">
        Commission a knife, leather piece or custom order — or just ask a question.
      </p>
    </div>
  </section>

  <!-- Wave: hero → mahogany -->
  <div class="-mb-1" style="background:#0a0d14;">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
      <path d="M0 80L80 65C160 50 320 20 480 15C640 10 800 30 960 38C1120 46 1280 38 1360 34L1440 30V80H0Z" fill="#1c0a04"/>
    </svg>
  </div>

  <!-- Contact Form & Info — mahogany -->
  <section class="py-24" style="background:#1c0a04;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Form -->
        <div class="animate-on-scroll">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 opacity-60" style="background:#c8a96e;"></div>
            <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#c8a96e;">Send a Message</span>
          </div>
          <h2 class="text-3xl font-bold text-white mb-2" style="font-family:'Cormorant Garamond',serif;">Start the Conversation</h2>
          <p class="text-gray-400 mb-8 text-sm leading-relaxed">Fill out the form and I'll get back to you about your inquiry.</p>

          <form
            action={`https://formspree.io/f/${config.integrations.formspree_id}`}
            method="POST"
            class="space-y-5"
            id="contact-form"
          >
            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color:#9ca3af;">Your Name *</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3.5 rounded-xl text-white placeholder-gray-600 focus:outline-none transition-all text-sm"
                style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); focus:border-color:#c8a96e;"
                placeholder="Your name" autocomplete="name" />
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color:#9ca3af;">Email Address *</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3.5 rounded-xl text-white placeholder-gray-600 focus:outline-none transition-all text-sm"
                style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);"
                placeholder="your@email.com" autocomplete="email" />
            </div>

            <div>
              <label for="inquiry-type" class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color:#9ca3af;">What are you looking for?</label>
              <select id="inquiry-type" name="inquiry-type"
                class="w-full px-4 py-3.5 rounded-xl text-white focus:outline-none transition-all text-sm"
                style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:#d1d5db;">
                <option value="" style="background:#1c0a04;">Select a type...</option>
                <option value="kitchen" style="background:#1c0a04;">Kitchen / Chef's Knife</option>
                <option value="hunting" style="background:#1c0a04;">Hunting / Field Knife</option>
                <option value="collector" style="background:#1c0a04;">Collector's / Art Knife</option>
                <option value="leather" style="background:#1c0a04;">Fine Leatherwork</option>
                <option value="gift" style="background:#1c0a04;">Gift Commission</option>
                <option value="question" style="background:#1c0a04;">General Question</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold uppercase tracking-widest mb-2" style="color:#9ca3af;">Message *</label>
              <textarea id="message" name="message" rows="6" required
                class="w-full px-4 py-3.5 rounded-xl text-white placeholder-gray-600 focus:outline-none transition-all text-sm resize-none"
                style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);"
                placeholder="Tell me what you're looking for — type of piece, intended use, any material preferences, size..."></textarea>
            </div>

            <input type="text" name="_gotcha" style="display:none" />

            <button type="submit" class="w-full text-white py-4 px-6 rounded-xl font-bold text-base tracking-wide transition-all hover:-translate-y-0.5 disabled:opacity-60" style="background:#d4500a; box-shadow:0 0 25px rgba(212,80,10,0.2);">
              Send Message
            </button>
          </form>

          <div id="form-status" class="mt-4 p-4 rounded-xl hidden" aria-live="polite" role="status">
            <p id="form-message"></p>
          </div>
        </div>

        <!-- Info -->
        <div class="animate-on-scroll">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 opacity-60" style="background:#d4500a;"></div>
            <span class="text-xs font-bold uppercase tracking-[0.2em]" style="color:#d4500a;">Direct Contact</span>
          </div>
          <h2 class="text-3xl font-bold text-white mb-2" style="font-family:'Cormorant Garamond',serif;">Reach Out Directly</h2>
          <p class="text-gray-400 mb-10 text-sm leading-relaxed">Prefer email? I'm happy to hear from you.</p>

          <div class="space-y-5 mb-10">
            <div class="flex items-center gap-4 p-5 rounded-2xl" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(212,80,10,0.12); border:1px solid rgba(212,80,10,0.2);">
                <svg class="w-5 h-5" style="color:#d4500a;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-0.5">Email</p>
                <a href={`mailto:${config.contact.email}`} class="text-white font-medium hover:underline transition-all">{config.contact.email}</a>
              </div>
            </div>

            <div class="flex items-center gap-4 p-5 rounded-2xl" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(200,169,110,0.1); border:1px solid rgba(200,169,110,0.2);">
                <svg class="w-5 h-5" style="color:#c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-0.5">Response Time</p>
                <p class="text-white font-medium">I aim to respond within a few days</p>
              </div>
            </div>
          </div>

          <!-- Tips -->
          <div class="rounded-3xl p-7" style="background:rgba(10,13,20,0.5); border:1px solid rgba(200,169,110,0.15);">
            <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#c8a96e;">Helpful to include:</p>
            <ul class="space-y-2.5">
              {[
                "Type of piece (knife, sheath, leatherwork, etc.)",
                "What it will be used for",
                "Size or blade length preference",
                "Material preferences",
                "Photos or references you like",
                "Budget range if you have one"
              ].map(tip => (
                <li class="flex items-start gap-2.5 text-sm text-gray-400">
                  <span class="w-1 h-1 rounded-full flex-shrink-0 mt-2" style="background:#d4500a;"></span>
                  {tip}
                </li>
              ))}
            </ul>
            <a href={`${base}artwork/`} class="inline-flex items-center gap-1.5 mt-5 text-xs font-bold uppercase tracking-widest transition-all hover:gap-3" style="color:#c8a96e;">
              Full ordering guide
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={contactJsonLd} />

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formStatus = document.getElementById('form-status');
    const formMessage = document.getElementById('form-message');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }
        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, { method: 'POST', body: formData, headers: { 'Accept': 'application/json' } });
          if (response.ok) {
            formStatus!.className = 'mt-4 p-4 rounded-xl';
            formStatus!.style.background = 'rgba(16,185,129,0.1)';
            formStatus!.style.border = '1px solid rgba(16,185,129,0.3)';
            formMessage!.textContent = "Thank you — I'll be in touch soon.";
            formMessage!.style.color = '#6ee7b7';
            formMessage!.className = 'font-medium text-sm';
            form.reset();
          } else { throw new Error('Failed'); }
        } catch {
          formStatus!.className = 'mt-4 p-4 rounded-xl';
          formStatus!.style.background = 'rgba(239,68,68,0.1)';
          formStatus!.style.border = '1px solid rgba(239,68,68,0.3)';
          formMessage!.textContent = 'Sorry, there was an error. Please email directly.';
          formMessage!.style.color = '#fca5a5';
          formMessage!.className = 'font-medium text-sm';
        }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Message'; }
        formStatus!.classList.remove('hidden');
      });
    }
  </script>

  <Footer slot="footer" />
</BaseLayout>
