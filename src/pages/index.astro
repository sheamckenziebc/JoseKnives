---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={config.site.title} description={config.site.description}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative py-28 md:py-40 overflow-hidden" style="background-color:#0f1923;">
    <!-- Background knife image with dark overlay -->
    <div class="absolute inset-0">
      <img
        src={`${base}assets/knife-01.jpg`}
        alt="Custom handforged knife by J.M. Amoedo"
        class="w-full h-full object-cover opacity-30"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,25,35,0.92) 0%, rgba(28,42,58,0.75) 100%);"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-5" style="color:#c8a96e;">Handcrafted Custom Knives</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight" style="font-family: 'Cormorant Garamond', serif;">
          Forged by Hand.<br />
          <span style="background: linear-gradient(90deg, #c8a96e, #e8c98e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Made to Last.</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 leading-relaxed max-w-2xl mb-10">
          Each blade is an original — shaped from raw steel, finished by hand, and built to perform for a lifetime. Custom orders welcome.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`${base}gallery/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-amber-500 transition-all shadow-lg hover:-translate-y-0.5">
            View the Gallery
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href={`${base}contact/`} class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/10 transition-all backdrop-blur-sm">
            Commission a Knife
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-14 flex flex-wrap gap-6">
          <div class="backdrop-blur-sm rounded-2xl p-5 min-w-[120px]" style="background: rgba(255,255,255,0.07); border: 1px solid rgba(200,169,110,0.2);">
            <div class="text-3xl font-extrabold" style="color:#c8a96e;">100%</div>
            <div class="text-xs text-gray-400 mt-1 uppercase tracking-wide">Hand Forged</div>
          </div>
          <div class="backdrop-blur-sm rounded-2xl p-5 min-w-[120px]" style="background: rgba(255,255,255,0.07); border: 1px solid rgba(200,169,110,0.2);">
            <div class="text-3xl font-extrabold" style="color:#c8a96e;">One of a Kind</div>
            <div class="text-xs text-gray-400 mt-1 uppercase tracking-wide">Every Blade</div>
          </div>
          <div class="backdrop-blur-sm rounded-2xl p-5 min-w-[120px]" style="background: rgba(255,255,255,0.07); border: 1px solid rgba(200,169,110,0.2);">
            <div class="text-3xl font-extrabold" style="color:#c8a96e;">Custom</div>
            <div class="text-xs text-gray-400 mt-1 uppercase tracking-wide">Orders Welcome</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="-mb-1" style="background-color:#0f1923;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- About the Maker -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="animate-on-scroll">
          <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">The Craft</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
            Every Knife Begins at the Forge
          </h2>
          <p class="text-lg text-gray-600 mb-5 leading-relaxed">
            J.M. Amoedo custom knives are built from the ground up — raw steel shaped through heat and hammer, ground to geometry, fitted with handles chosen for character and durability.
          </p>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            No two blades are alike. Whether you need a chef's workhorse, a field knife, or a collector's piece, each order starts with a conversation about how the knife will be used.
          </p>
          <a href={`${base}about/`} class="inline-flex items-center font-semibold text-lg hover:gap-3 transition-all gap-2" style="color:#1c2a3a;">
            Meet the Maker
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="relative animate-on-scroll">
          <img
            src={`${base}assets/knife-02.jpg`}
            alt="Handcrafted knife by J.M. Amoedo"
            class="rounded-3xl shadow-2xl w-full h-96 object-cover"
            loading="lazy"
            onerror="this.src=''; this.style.display='none';"
          />
          <div class="absolute -bottom-4 -right-4 w-32 h-32 rounded-3xl opacity-20" style="background-color:#c8a96e;"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Make -->
  <section class="py-20" style="background-color:#f5f1e8;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">The Collection</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          Browse by Type
        </h2>
        <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <!-- Kitchen & Chef -->
        <a href={`${base}gallery/`} class="animate-on-scroll group bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center card-hover">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6 card-icon" style="background-color:#e8f0f8;">
            <svg class="w-8 h-8" style="color:#1c2a3a;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1M3 12h1m16 0h1M5.6 5.6l.7.7m11.4-.7l-.7.7M5.6 18.4l.7-.7m11.4.7l-.7-.7"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">Kitchen & Chef's Knives</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Culinary blades built for balance and edge retention — chef's knives, santokus, cleavers and more.</p>
          <span class="inline-flex items-center font-semibold text-sm mt-4 group-hover:gap-2 gap-1 transition-all" style="color:#c8a96e;">
            View Gallery
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>

        <!-- Hunting & Field -->
        <a href={`${base}gallery/`} class="animate-on-scroll group bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center card-hover">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6 card-icon" style="background-color:#e8f0f8;">
            <svg class="w-8 h-8" style="color:#1c2a3a;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7l9-4 9 4v10l-9 4-9-4V7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">Hunting & Field Knives</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Fixed-blade field knives designed for hard use — skinning, camp work and outdoor carry.</p>
          <span class="inline-flex items-center font-semibold text-sm mt-4 group-hover:gap-2 gap-1 transition-all" style="color:#c8a96e;">
            View Gallery
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>

        <!-- Collector's Pieces -->
        <a href={`${base}gallery/`} class="animate-on-scroll group bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center card-hover">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6 card-icon" style="background-color:#e8f0f8;">
            <svg class="w-8 h-8" style="color:#1c2a3a;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3l14 9-14 9V3z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">Collector's Pieces</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Art knives and presentation pieces for collectors — exceptional materials, intricate handle work, display-ready.</p>
          <span class="inline-flex items-center font-semibold text-sm mt-4 group-hover:gap-2 gap-1 transition-all" style="color:#c8a96e;">
            View Gallery
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Wave Divider into dark -->
  <div class="-mb-1" style="background-color:#f5f1e8;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 0L60 8C120 16 240 32 360 36C480 40 600 32 720 28C840 24 960 24 1080 28C1200 32 1320 40 1380 44L1440 48V0H1380C1320 0 1200 0 1080 0C960 0 840 0 720 0C600 0 480 0 360 0C240 0 120 0 60 0H0Z" fill="#0f1923"/>
    </svg>
  </div>

  <!-- Featured Work (image grid) -->
  <section class="py-20" style="background-color:#0f1923;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="font-semibold text-sm uppercase tracking-widest" style="color:#c8a96e;">Recent Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          From the Workshop
        </h2>
        <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 stagger-children">
        {[3,4,5,6,7,8,9,10].map((n) => (
          <div class="animate-on-scroll group overflow-hidden rounded-2xl aspect-square" style="background-color:#1c2a3a;">
            <img
              src={`${base}assets/knife-${String(n).padStart(2,'0')}.jpg`}
              alt={`Custom knife by J.M. Amoedo`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.parentElement.style.display='none';"
            />
          </div>
        ))}
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a href={`${base}gallery/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-amber-500 transition-all shadow-lg hover:-translate-y-0.5">
          View Full Gallery
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Wave Divider back to light -->
  <div class="-mb-1" style="background-color:#0f1923;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Why Custom -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="relative animate-on-scroll order-2 lg:order-1">
          <img
            src={`${base}assets/knife-11.jpg`}
            alt="Detail of custom knife handle and blade"
            class="rounded-3xl shadow-2xl w-full h-96 object-cover"
            loading="lazy"
            onerror="this.src=''; this.style.display='none';"
          />
          <div class="absolute -top-4 -left-4 w-32 h-32 rounded-3xl opacity-15" style="background-color:#1c2a3a;"></div>
        </div>
        <div class="animate-on-scroll order-1 lg:order-2">
          <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">Why Custom?</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
            A Knife Built Around You
          </h2>
          <div class="space-y-5">
            {[
              { title: "Your dimensions", desc: "Handle length, blade geometry and balance tuned to the way you work." },
              { title: "Your materials", desc: "Choose your steel, handle material and finish — from practical to heirloom." },
              { title: "Your purpose", desc: "Whether it's a kitchen workhorse, a hunting companion or a gift, the design starts there." },
              { title: "Your timeline", desc: "Each knife is made to order. Contact me to discuss what you have in mind." }
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-1" style="background-color:#fef3c7;">
                  <svg class="w-4 h-4" style="color:#c8a96e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">{item.title}</p>
                  <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-24 overflow-hidden" style="background-color:#1c2a3a;">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot; fill-rule=&quot;evenodd&quot;%3E%3Ccircle cx=&quot;30&quot; cy=&quot;30&quot; r=&quot;3&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="font-semibold text-sm uppercase tracking-widest" style="color:#c8a96e;">Ready to Start?</span>
      <h2 class="text-3xl md:text-5xl font-bold text-white mt-3 mb-6" style="font-family: 'Cormorant Garamond', serif;">
        Commission Your Custom Knife
      </h2>
      <p class="text-xl text-gray-300 mb-10 leading-relaxed">
        Get in touch to discuss your project. Every knife starts with a conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-amber-500 transition-all shadow-lg hover:-translate-y-0.5">
          Start a Commission
        </a>
        <a href={`${base}artwork/`} class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/10 transition-all">
          How It Works
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
