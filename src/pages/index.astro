---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={config.site.title} description={config.site.description}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-stone-900 via-red-900 to-stone-800 py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.08&quot;%3E%3Ccircle cx=&quot;30&quot; cy=&quot;30&quot; r=&quot;4&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-block text-amber-400 font-medium text-sm uppercase tracking-widest mb-4">Studio & Gallery — Telkwa, BC</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6" style="font-family: 'Cormorant Garamond', serif;">
          Art and Soul <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">Pottery</span>
        </h1>
        <p class="text-xl md:text-2xl text-red-100 leading-relaxed max-w-3xl mx-auto mb-8">
          Handmade, artistic and functional pottery by Franziska Cody
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`${base}gallery/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-500 transition-all shadow-lg hover:-translate-y-0.5">
            View Pottery Gallery
          </a>
          <a href={`${base}contact/`} class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all">
            Visit the Studio
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-12 grid grid-cols-3 gap-6 max-w-md mx-auto">
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
            <div class="text-2xl font-extrabold text-white">Since</div>
            <div class="text-2xl font-extrabold text-amber-400">2009</div>
            <div class="text-xs text-red-200 mt-1">Studio & Gallery</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
            <div class="text-2xl font-extrabold text-amber-400"><span data-count="17" data-suffix="+">0+</span></div>
            <div class="text-xs text-red-200 mt-1">Years in Clay</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4">
            <div class="text-2xl font-extrabold text-amber-400">Hwy 16</div>
            <div class="text-xs text-red-200 mt-1">Telkwa, BC</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-stone-900 via-red-900 to-stone-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- About the Studio -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span class="text-red-800 font-semibold text-sm uppercase tracking-wider">Welcome</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
            Studio and Gallery
          </h2>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            Art and Soul Pottery Studio and Gallery is located at 1269 Hwy 16, Telkwa, BC and is your source to handmade, artistic and functional pottery.
          </p>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            Offering a wide range of food, microwave and oven safe pottery by Franziska Cody, as well as crafts from local artisans, Art and Soul Pottery also supports artisans from around the world by offering their products through the gallery.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            The "working studio" provides the opportunity to witness the process of creating pottery and to custom make items to meet specific interests.
          </p>
        </div>
        <div class="relative animate-on-scroll">
          <img
            src={`${base}assets/studio-front.jpg`}
            alt="Art and Soul Pottery studio front in Telkwa, BC"
            class="rounded-2xl shadow-lg w-full h-96 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-red-800 font-semibold text-sm uppercase tracking-wider">What We Offer</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          Browse Our Collections
        </h2>
        <div class="w-16 h-1 bg-amber-500 mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <a href={`${base}gallery/`} class="animate-on-scroll group bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-amber-100 transition-colors">
            <svg class="w-8 h-8 text-red-800 group-hover:text-amber-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">Pottery Gallery</h3>
          <p class="text-gray-600 leading-relaxed">Functional dinnerware, decorative vessels, vases, mugs and more — all handmade, food safe and oven safe.</p>
          <span class="inline-flex items-center text-red-800 font-semibold text-sm mt-4 group-hover:text-amber-600 transition-colors">
            View Gallery
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>

        <a href={`${base}artwork/`} class="animate-on-scroll group bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-amber-100 transition-colors">
            <svg class="w-8 h-8 text-red-800 group-hover:text-amber-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">Other Artwork</h3>
          <p class="text-gray-600 leading-relaxed">Paintings, sculptures, murals, cards, photography — by Franziska and other local artisans.</p>
          <span class="inline-flex items-center text-red-800 font-semibold text-sm mt-4 group-hover:text-amber-600 transition-colors">
            View Artwork
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>

        <a href={`${base}gifts/`} class="animate-on-scroll group bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-amber-100 transition-colors">
            <svg class="w-8 h-8 text-red-800 group-hover:text-amber-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3" style="font-family: 'Cormorant Garamond', serif;">Other Gifts</h3>
          <p class="text-gray-600 leading-relaxed">Silver and gem jewellery, bags and prayer flags from Nepal and Thailand, and other unique gifts.</p>
          <span class="inline-flex items-center text-red-800 font-semibold text-sm mt-4 group-hover:text-amber-600 transition-colors">
            View Gifts
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Working Studio Feature -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative animate-on-scroll order-2 lg:order-1">
          <img
            src={`${base}assets/studio-gallery.jpg`}
            alt="Inside Art and Soul Pottery gallery"
            class="rounded-2xl shadow-lg w-full h-96 object-cover"
            loading="lazy"
          />
        </div>
        <div class="animate-on-scroll order-1 lg:order-2">
          <span class="text-red-800 font-semibold text-sm uppercase tracking-wider">Working Studio</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
            Watch Pottery Come to Life
          </h2>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p class="text-gray-600 leading-relaxed">Watch a piece being created from start to finish in the working studio</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p class="text-gray-600 leading-relaxed">Custom orders available — combining form, colour and images in unique ways to suit your interests</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p class="text-gray-600 leading-relaxed">All pottery is food safe, microwave safe and oven safe — fired to 1220°C</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p class="text-gray-600 leading-relaxed">Supporting local and international artisans through the gallery</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Opening Hours -->
  <section class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center animate-on-scroll">
        <span class="text-red-800 font-semibold text-sm uppercase tracking-wider">Plan Your Visit</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-8" style="font-family: 'Cormorant Garamond', serif;">
          Opening Hours
        </h2>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left max-w-md mx-auto">
            <div class="flex justify-between py-2 border-b border-gray-100">
              <span class="font-medium text-gray-900">Monday</span>
              <span class="text-gray-600">10am — 5pm</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-100">
              <span class="font-medium text-gray-900">Tuesday</span>
              <span class="text-gray-400 italic">By appointment</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-100">
              <span class="font-medium text-gray-900">Wednesday</span>
              <span class="text-gray-600">10am — 5pm</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-100">
              <span class="font-medium text-gray-900">Thursday</span>
              <span class="text-gray-600">10am — 5pm</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-100">
              <span class="font-medium text-gray-900">Friday</span>
              <span class="text-gray-400 italic">By appointment</span>
            </div>
            <div class="flex justify-between py-2 border-b border-gray-100">
              <span class="font-medium text-gray-900">Sat & Sun</span>
              <span class="text-gray-400 italic">By appointment</span>
            </div>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`tel:${config.contact.phone}`} class="inline-flex items-center justify-center bg-red-800 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-red-900 transition-all shadow-lg">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call {config.contact.phone}
          </a>
          <a href={`mailto:${config.contact.email}`} class="inline-flex items-center justify-center border-2 border-red-800 text-red-800 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-red-50 transition-all">
            Email Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Kabir Poem CTA -->
  <section class="relative py-20 bg-gradient-to-br from-red-900 to-stone-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.1&quot; fill-rule=&quot;evenodd&quot;%3E%3Ccircle cx=&quot;20&quot; cy=&quot;20&quot; r=&quot;3&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <blockquote class="mb-8">
        <p class="text-xl md:text-2xl text-red-100 leading-relaxed italic" style="font-family: 'Cormorant Garamond', serif;">
          "Inside this clay jug, there are canyons and pine mountains, and the maker of canyons and pine mountains. All seven oceans are inside and hundreds of millions of stars."
        </p>
        <p class="text-lg text-red-200 mt-4 italic" style="font-family: 'Cormorant Garamond', serif;">
          "If you want the truth, I will tell you; friend listen: the god I love is inside!"
        </p>
        <cite class="text-amber-400 text-sm mt-4 block not-italic font-semibold">— Kabir</cite>
      </blockquote>
      <a href={`${base}about/`} class="inline-flex items-center justify-center bg-amber-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-500 transition-all shadow-lg">
        Meet the Artist
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
