---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`Terms of Service | ${config.site.title}`} description="Terms of service for J.M. Amoedo Custom Knives." noindex={true}>
  <Header slot="header" />

  <section class="relative py-16" style="background-color:#1c2a3a;">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold text-white" style="font-family: 'Cormorant Garamond', serif;">Terms of Service</h1>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg text-gray-600">
      <p>These terms govern your use of the J.M. Amoedo Custom Knives website and the commissioning of custom blades.</p>

      <h2 class="text-gray-900">Custom Orders</h2>
      <p>All knives are made to order. Lead times vary depending on current workload and will be discussed at the time of inquiry. Custom orders involve a design consultation process before production begins. Final pricing is agreed upon before work starts.</p>

      <h2 class="text-gray-900">Pricing</h2>
      <p>Pricing for custom work is determined on a per-project basis depending on design complexity, materials, and current workload. A deposit may be required before production begins.</p>

      <h2 class="text-gray-900">Handmade Nature</h2>
      <p>All knives are handmade. Slight variations from any reference images or examples are inherent to handmade work. Each blade is an original. We take care to meet agreed specifications but natural variation in materials is expected.</p>

      <h2 class="text-gray-900">Safety</h2>
      <p>Custom knives are sharp tools. By purchasing or commissioning a knife, you accept responsibility for safe handling, storage and use. These knives are intended for use by adults.</p>

      <h2 class="text-gray-900">Jurisdiction</h2>
      <p>These terms are governed by applicable law in the jurisdiction where the maker operates.</p>

      <h2 class="text-gray-900">Contact</h2>
      <p>Questions about these terms can be directed to <a href={`mailto:${config.contact.email}`} style="color:#1c2a3a;">{config.contact.email}</a>.</p>

      <p class="text-sm text-gray-400 mt-8">Last updated: April 2026</p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
