---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const steps = [
  {
    number: "01",
    title: "Get in Touch",
    desc: "Send an email describing what you have in mind — knife type, intended use, any handle material or steel preferences, and budget if you have one. No idea is too vague to start with."
  },
  {
    number: "02",
    title: "Design Discussion",
    desc: "We'll go back and forth on the details: blade profile, length, grind, handle shape and materials. Photos of similar work are welcome. This stage ensures the knife is built around your needs."
  },
  {
    number: "03",
    title: "Forging & Grinding",
    desc: "Work begins at the forge. The blade profile is cut and shaped, then ground to geometry. Heat treatment is done in-house to achieve the target hardness for the steel selected."
  },
  {
    number: "04",
    title: "Handle Work & Finishing",
    desc: "Handle materials are shaped, fitted and secured. The blade is hand-sanded through progressive grits to the agreed finish. Every edge is sharpened before the knife goes out."
  },
  {
    number: "05",
    title: "Delivery",
    desc: "Completed knives are shipped carefully or arranged for pickup. A basic care card is included. Lead time varies — typically several weeks depending on current workload."
  }
];
---

<BaseLayout title={`Custom Orders | ${config.site.title}`} description="How to commission a custom knife from J.M. Amoedo. Every blade is made to order — from design consultation through forging, finishing and delivery.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative py-24 overflow-hidden" style="background-color:#0f1923;">
    <div class="absolute inset-0">
      <img
        src={`${base}assets/knife-09.jpg`}
        alt="Custom knife commission process"
        class="w-full h-full object-cover opacity-20"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,25,35,0.92) 0%, rgba(28,42,58,0.75) 100%);"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="font-semibold text-sm uppercase tracking-wider mb-4 block" style="color:#c8a96e;">Bespoke Blades</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
        Custom <span style="background: linear-gradient(90deg, #c8a96e, #e8c98e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Orders</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        Every knife starts with a conversation. Here's how to commission one.
      </p>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="-mb-1" style="background-color:#0f1923;">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Process Steps -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">The Process</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          From Inquiry to Finished Knife
        </h2>
        <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
      </div>

      <div class="space-y-8 stagger-children">
        {steps.map(step => (
          <div class="animate-on-scroll flex gap-6 items-start bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="text-4xl font-extrabold flex-shrink-0 w-16 text-right leading-none mt-1" style="color:#c8a96e; font-family: 'Cormorant Garamond', serif;">{step.number}</div>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-gray-900 mb-2" style="font-family: 'Cormorant Garamond', serif;">{step.title}</h3>
              <p class="text-gray-600 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to Include -->
  <section class="py-20" style="background-color:#f5f1e8;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">
        <div class="animate-on-scroll">
          <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">Your Inquiry</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6" style="font-family: 'Cormorant Garamond', serif;">
            What to Include in Your Message
          </h2>
          <div class="space-y-4">
            {[
              "What type of knife you're looking for (chef's, hunter, collector, etc.)",
              "Intended primary use",
              "Approximate blade length or overall size preference",
              "Handle material preferences (wood, bone, synthetic, etc.)",
              "Any finish preference (satin, mirror, patina, etc.)",
              "Budget range if you have one",
              "Photos or references of styles you like"
            ].map(item => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color:#1c2a3a;">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <p class="text-gray-700">{item}</p>
              </div>
            ))}
          </div>
          <p class="mt-6 text-gray-500 text-sm italic">
            Don't worry if you don't have all the answers — the conversation will help clarify the details.
          </p>
        </div>
        <div class="animate-on-scroll">
          <div class="rounded-3xl p-8 md:p-10" style="background-color:#1c2a3a;">
            <h3 class="text-2xl font-bold text-white mb-2" style="font-family: 'Cormorant Garamond', serif;">Ready to Start?</h3>
            <p class="text-gray-300 mb-6 leading-relaxed">Send an email to begin the conversation. I'll respond as soon as I can.</p>
            <a
              href={`mailto:${config.contact.email}`}
              class="inline-flex items-center bg-amber-600 text-white px-6 py-3.5 rounded-xl font-bold hover:bg-amber-500 transition-all mb-6 w-full justify-center"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {config.contact.email}
            </a>
            <a
              href={`${base}contact/`}
              class="inline-flex items-center border-2 border-white/30 text-white px-6 py-3.5 rounded-xl font-semibold hover:bg-white/10 transition-all w-full justify-center"
            >
              Use the Contact Form
            </a>
            <div class="mt-8 pt-6 border-t border-white/10">
              <p class="text-gray-400 text-sm">
                All knives are made to order. Lead time depends on current workload — usually a few weeks. Ask when you get in touch.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sample Work -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="font-semibold text-sm uppercase tracking-wider" style="color:#1c2a3a;">Examples</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4" style="font-family: 'Cormorant Garamond', serif;">
          Past Custom Orders
        </h2>
        <div class="mt-4 h-1 w-16 rounded mx-auto" style="background-color:#c8a96e;"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 stagger-children">
        {[9,10,14,16].map((n) => (
          <div class="animate-on-scroll overflow-hidden rounded-2xl aspect-square bg-gray-100">
            <img
              src={`${base}assets/knife-${String(n).padStart(2,'0')}.jpg`}
              alt="Custom commissioned knife by J.M. Amoedo"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.parentElement.style.display='none';"
            />
          </div>
        ))}
      </div>
      <div class="text-center mt-10 animate-on-scroll">
        <a href={`${base}gallery/`} class="inline-flex items-center justify-center text-white px-8 py-4 rounded-2xl font-bold text-lg transition-all shadow-lg hover:-translate-y-0.5" style="background-color:#1c2a3a;">
          View Full Gallery
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
